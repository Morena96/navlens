# The example's native platform folders are regenerated by `flutter create .`
# and bloat the pub.dev tarball by ~200 KB without adding value for package
# consumers — they can run the command themselves after cloning.
example/android/
example/ios/
example/macos/
example/windows/
example/linux/
example/web/
example/build/
example/.dart_tool/
example/.idea/
example/ios/Pods/
example/navlens_example.iml

# Build output, IDE files, and test coverage artefacts never belong in a
# published archive.
build/
.dart_tool/
.idea/
coverage/
*.iml
